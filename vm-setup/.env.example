#===============================================================================
# vm-setup/.env.example
# Copy to vm-setup/.env and fill in your values before running setup scripts.
# .env is gitignored — never commit it with real credentials.
#===============================================================================

# ── Windows VM credentials ──────────────────────────────────────────────────
# Local account created inside the Windows 11 VM.
# Change these before running 02-create-win11-vm.sh.
WIN_USER=architect
WIN_PASS=Sparx2026!          # CHANGE THIS

# ── Sparx EA edition ────────────────────────────────────────────────────────
# Controls which MSI is downloaded in Step 7 of 01-setup-vmware-fusion.sh.
#
#   trial    (default) — full EA, 30-day limit, no auth required
#                        MCP3.exe COM bridge: YES
#   lite               — EA Lite Viewer, free forever, read-only, no auth
#                        MCP3.exe COM bridge: NO (no COM automation API)
#                        SQLite Analyzer MCP on macOS: YES (unaffected)
#   licensed           — full licensed EA; place easetupfull.msi in ./iso/
#                        or set EA_REG_USER + EA_REG_PASS below
#                        MCP3.exe COM bridge: YES
#
EA_EDITION=trial

# ── Sparx registered-user credentials (licensed edition only) ───────────────
# If EA_EDITION=licensed and easetupfull.msi is not already in ./iso/,
# the script opens the registered-user download page and prints these
# credentials as a reminder. The page itself requires a manual browser login.
# EA_REG_USER=your@email.com
# EA_REG_PASS=yourRegisteredPassword
